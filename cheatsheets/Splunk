## 🚨 SSH Brute Force Detection (Project 1)

```spl
-- Find all failed SSH login attempts
index=lab_logs "Failed password"
| table _time, src_ip, user, host

-- Count failed attempts per source IP
index=lab_logs "Failed password"
| stats count by src_ip
| sort -count

-- Alert threshold: more than 5 failures from one IP
index=lab_logs "Failed password"
| stats count by src_ip
| where count > 5
| sort -count

-- Timeline of brute force attack
index=lab_logs "Failed password"
| timechart span=1m count by src_ip

-- Find successful login after brute force (compromise indicator)
index=lab_logs ("Failed password" OR "Accepted password")
| stats count(eval(match(_raw,"Failed"))) as failures,
        count(eval(match(_raw,"Accepted"))) as successes by src_ip
| where failures > 5 AND successes > 0
```

